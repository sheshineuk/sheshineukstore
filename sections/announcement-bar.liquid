{% comment %} SheShine — Announcement Bar {% endcomment %}

{% if section.settings.show_announcement %}
<div class="sheshine-announcement"
     style="background-color: {{ section.settings.bg_color }};
            color: {{ section.settings.text_color }};">

  {%- comment -%} Desktop: 3 items side by side {%- endcomment -%}
  <div class="sheshine-announcement__desktop">
    <div class="sheshine-announcement__item">
      <span class="sheshine-announcement__icon">🚚</span>
      <span>{{ section.settings.usp_1 }}</span>
    </div>
    <div class="sheshine-announcement__divider">|</div>
    <div class="sheshine-announcement__item">
      <span class="sheshine-announcement__icon">↩</span>
      <span>{{ section.settings.usp_2 }}</span>
    </div>
    <div class="sheshine-announcement__divider">|</div>
    <div class="sheshine-announcement__item">
      <span class="sheshine-announcement__icon">🔒</span>
      <span>{{ section.settings.usp_3 }}</span>
    </div>
  </div>

  {%- comment -%} Mobile: rotating messages {%- endcomment -%}
  <div class="sheshine-announcement__mobile">
    <div class="sheshine-announcement__mobile-track">
      <span class="sheshine-announcement__mobile-item">🚚 {{ section.settings.usp_1 }}</span>
      <span class="sheshine-announcement__mobile-item">↩ {{ section.settings.usp_2 }}</span>
      <span class="sheshine-announcement__mobile-item">🔒 {{ section.settings.usp_3 }}</span>
    </div>
  </div>
</div>
{% endif %}

<style>
  .sheshine-announcement {
    width: 100%;
    padding: 10px 20px;
    text-align: center;
    font-family: var(--sheshine-font-body);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.3px;
    position: relative;
    z-index: 100;
  }

  /* Desktop layout */
  .sheshine-announcement__desktop {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 24px;
  }
  .sheshine-announcement__item {
    display: flex;
    align-items: center;
    gap: 7px;
  }
  .sheshine-announcement__icon {
    font-size: 15px;
  }
  .sheshine-announcement__divider {
    opacity: 0.35;
    font-size: 16px;
  }

  /* Mobile layout - rotating */
  .sheshine-announcement__mobile {
    display: none;
    overflow: hidden;
    height: 22px;
  }
  .sheshine-announcement__mobile-track {
    display: flex;
    flex-direction: column;
    animation: sheshine-rotate-usps 6s ease-in-out infinite;
  }
  .sheshine-announcement__mobile-item {
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    white-space: nowrap;
    flex-shrink: 0;
  }

  @keyframes sheshine-rotate-usps {
    0%, 28%   { transform: translateY(0); }
    33%, 61%  { transform: translateY(-22px); }
    66%, 94%  { transform: translateY(-44px); }
    100%      { transform: translateY(-66px); }
  }

  @media (max-width: 768px) {
    .sheshine-announcement__desktop { display: none; }
    .sheshine-announcement__mobile  { display: block; }
    .sheshine-announcement { padding: 9px 16px; font-size: 12px; }
  }
</style>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement bar",
      "default": true
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background colour",
      "default": "#674170"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text colour",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "usp_1",
      "label": "USP 1",
      "default": "Free UK Shipping on Orders Over £30"
    },
    {
      "type": "text",
      "id": "usp_2",
      "label": "USP 2",
      "default": "Easy 30-Day Returns"
    },
    {
      "type": "text",
      "id": "usp_3",
      "label": "USP 3",
      "default": "Secure Checkout Guaranteed"
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ]
}
{% endschema %}
