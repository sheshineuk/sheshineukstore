{% comment %} SheShine — Best Sellers Grid {% endcomment %}

{% if section.settings.show_section %}
<section class="sheshine-bestsellers"
         style="background: {{ section.settings.bg_color }};">
  <div class="sheshine-container">

    <div class="sheshine-bestsellers__header">
      <span class="sheshine-section-tag">{{ section.settings.tag }}</span>
      <h2 class="sheshine-section-title">{{ section.settings.heading }}</h2>
      <p class="sheshine-section-subtitle">{{ section.settings.subheading }}</p>
    </div>

    {%- assign featured = section.settings.collection -%}
    {%- if featured != blank -%}
      <div class="sheshine-product-grid">
        {%- for product in featured.products limit: section.settings.products_count -%}
          <div class="sheshine-product-card sheshine-reveal" style="transition-delay: {{ forloop.index0 | times: 80 }}ms">
            <div class="sheshine-product-card__img-wrap">
              <a href="{{ product.url }}">
                {%- if product.featured_image -%}
                  <img src="{{ product.featured_image | image_url: width: 600 }}"
                       alt="{{ product.featured_image.alt | escape }}"
                       loading="lazy"
                       class="sheshine-product-card__image">
                {%- else -%}
                  <div class="sheshine-product-card__no-img">
                    <span>{{ product.title }}</span>
                  </div>
                {%- endif -%}
              </a>

              {%- if product.compare_at_price > product.price -%}
                {%- assign saving = product.compare_at_price | minus: product.price -%}
                {%- assign saving_pct = saving | times: 100 | divided_by: product.compare_at_price -%}
                <span class="sheshine-product-card__badge">SAVE {{ saving_pct }}%</span>
              {%- elsif product.tags contains 'new' -%}
                <span class="sheshine-product-card__badge sheshine-product-card__badge--new">NEW</span>
              {%- endif -%}
            </div>

            <div class="sheshine-product-card__body">
              <a href="{{ product.url }}" class="sheshine-product-card__title">
                {{ product.title }}
              </a>
              <div class="sheshine-product-card__price">
                {%- if product.compare_at_price > product.price -%}
                  <span class="sheshine-product-card__price--sale">
                    {{ product.price | money }}
                  </span>
                  <span class="sheshine-product-card__price--compare">
                    {{ product.compare_at_price | money }}
                  </span>
                {%- else -%}
                  <span class="sheshine-product-card__price--regular">
                    {{ product.price | money }}
                  </span>
                {%- endif -%}
              </div>

              <form action="/cart/add" method="post">
                <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                <button type="submit" class="sheshine-btn-primary sheshine-product-card__atc">
                  Add to Cart
                </button>
              </form>
            </div>
          </div>
        {%- endfor -%}
      </div>

      {%- if section.settings.show_view_all -%}
        <div class="sheshine-bestsellers__footer">
          <a href="{{ featured.url }}" class="sheshine-btn-secondary">
            {{ section.settings.view_all_text }}
          </a>
        </div>
      {%- endif -%}
    {%- else -%}
      <p style="text-align:center; color: var(--sheshine-text-muted); font-family: var(--sheshine-font-body);">
        Select a collection in the Theme Editor to display products here.
      </p>
    {%- endif -%}

  </div>
</section>
{% endif %}

<style>
.sheshine-bestsellers {
  padding: 80px 0;
}

.sheshine-bestsellers__header {
  margin-bottom: 48px;
}

/* Product Grid */
.sheshine-product-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
}

/* Product Card */
.sheshine-product-card {
  background: var(--sheshine-white);
  border-radius: var(--sheshine-radius-md);
  overflow: hidden;
  border: 1px solid var(--sheshine-border);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  display: flex;
  flex-direction: column;
}

.sheshine-product-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 16px 48px rgba(103, 65, 112, 0.14);
}

.sheshine-product-card__img-wrap {
  position: relative;
  overflow: hidden;
  aspect-ratio: 1/1;
  background: var(--sheshine-soft);
}

.sheshine-product-card__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
}

.sheshine-product-card:hover .sheshine-product-card__image {
  transform: scale(1.06);
}

.sheshine-product-card__no-img {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--sheshine-soft), #f5e8f4);
  font-family: var(--sheshine-font-heading);
  font-size: 16px;
  color: var(--sheshine-primary);
  padding: 16px;
  text-align: center;
}

.sheshine-product-card__badge {
  position: absolute;
  top: 12px;
  left: 12px;
  background: var(--sheshine-primary);
  color: white;
  font-family: var(--sheshine-font-body);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.5px;
  padding: 4px 10px;
  border-radius: var(--sheshine-radius-pill);
  z-index: 1;
}

.sheshine-product-card__badge--new {
  background: var(--sheshine-secondary);
}

.sheshine-product-card__body {
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  flex: 1;
}

.sheshine-product-card__title {
  font-family: var(--sheshine-font-body);
  font-size: 14px;
  font-weight: 600;
  color: var(--sheshine-text);
  text-decoration: none;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.sheshine-product-card__title:hover {
  color: var(--sheshine-primary);
}

.sheshine-product-card__price {
  display: flex;
  align-items: center;
  gap: 8px;
}

.sheshine-product-card__price--sale {
  font-family: var(--sheshine-font-body);
  font-size: 15px;
  font-weight: 700;
  color: var(--sheshine-primary);
}

.sheshine-product-card__price--compare {
  font-family: var(--sheshine-font-body);
  font-size: 13px;
  color: var(--sheshine-text-muted);
  text-decoration: line-through;
}

.sheshine-product-card__price--regular {
  font-family: var(--sheshine-font-body);
  font-size: 15px;
  font-weight: 700;
  color: var(--sheshine-primary);
}

.sheshine-product-card__atc {
  width: 100%;
  padding: 11px 16px;
  font-size: 13px;
  margin-top: auto;
}

/* View All Button */
.sheshine-bestsellers__footer {
  text-align: center;
  margin-top: 48px;
}

/* Responsive */
@media (max-width: 1024px) {
  .sheshine-product-grid { grid-template-columns: repeat(3, 1fr); }
}

@media (max-width: 768px) {
  .sheshine-bestsellers { padding: 48px 0; }
  .sheshine-product-grid { grid-template-columns: repeat(2, 1fr); gap: 14px; }
  .sheshine-bestsellers__header { margin-bottom: 28px; }
}

@media (max-width: 400px) {
  .sheshine-product-grid { grid-template-columns: 1fr; }
}
</style>

{% schema %}
{
  "name": "Best Sellers Grid",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background colour",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "tag",
      "label": "Tag above heading",
      "default": "Top Picks"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Best Sellers"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Our most-loved products, trusted by thousands of UK women."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection to display"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Number of products",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show View All button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View All button text",
      "default": "View All Products"
    }
  ],
  "presets": [{ "name": "Best Sellers Grid" }]
}
{% endschema %}
